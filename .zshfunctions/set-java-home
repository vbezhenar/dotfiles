set-java-home() {
  local p
  case "$1" in
    '')
      p='/opt/jdk-21+35/Contents/Home'
      ;;
    '8')
      p='/opt/zulu8.72.0.17-ca-fx-jdk8.0.382-macosx_aarch64'
      ;;
    '11')
      p='/opt/jdk-11.0.20.1+1/Contents/Home'
      ;;
    '17')
      p='/opt/jdk-17.0.9+9/Contents/Home'
      ;;
    '21')
      p='/opt/jdk-21+35/Contents/Home'
      ;;
    *)
      echo >&2 'Usage: set-java-home [8|11|17|21]'
      return 1
  esac
  echo "JAVA_HOME=${p}"
  JAVA_HOME="${p}"
}
