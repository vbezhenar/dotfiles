set-java-home() {
  local p
  case "$1" in
    '')
      p='/opt/java/jdk-21'
      ;;
    '8')
      p='/opt/java/jdk-8'
      ;;
    '11')
      p='/opt/java/jdk-11'
      ;;
    '17')
      p='/opt/java/jdk-17'
      ;;
    '21')
      p='/opt/java/jdk-21'
      ;;
    *)
      echo >&2 'Usage: set-java-home [8|11|17|21]'
      return 1
  esac
  echo "JAVA_HOME=${p}"
  JAVA_HOME="${p}"
}
